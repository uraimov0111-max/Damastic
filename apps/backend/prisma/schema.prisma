generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DriverStatus {
  offline
  online
}

enum QueueStatus {
  active
  left
  served
}

enum PaymentStatus {
  pending
  success
  failed
}

enum PaymentSystem {
  click
  payme
}

enum AllianceStatus {
  active
  inactive
}

enum VehicleStatus {
  active
  blocked
  maintenance
}

enum AdminRole {
  super_admin
  alliance_admin
}

enum QueueEventType {
  joined
  left
  auto_shift
  served
  forced_remove
}

enum LedgerEntryType {
  electronic_in
  cash_in
  payout_out
  adjustment_in
  adjustment_out
}

model Alliance {
  id          BigInt         @id @default(autoincrement())
  name        String
  slug        String         @unique
  status      AllianceStatus @default(active)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  admins      AdminUser[]
  drivers     Driver[]
  vehicles    Vehicle[]
  routes      Route[]
  cashEntries CashEntry[]

  @@map("alliances")
}

model AdminUser {
  id           BigInt     @id @default(autoincrement())
  allianceId   BigInt?    @map("alliance_id")
  fullName     String     @map("full_name")
  email        String     @unique
  passwordHash String     @map("password_hash")
  role         AdminRole
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  alliance     Alliance?  @relation(fields: [allianceId], references: [id], onDelete: SetNull)

  @@index([allianceId, role])
  @@map("admin_users")
}

model Driver {
  id            BigInt         @id @default(autoincrement())
  allianceId    BigInt?        @map("alliance_id")
  vehicleId     BigInt?        @unique @map("vehicle_id")
  name          String
  phone         String         @unique
  carNumber     String         @unique @map("car_number")
  cardNumber    String?        @map("card_number")
  paymentSlug   String         @unique @map("payment_slug")
  status        DriverStatus   @default(offline)
  routeId       BigInt?        @map("route_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  alliance      Alliance?      @relation(fields: [allianceId], references: [id], onDelete: SetNull)
  route         Route?         @relation(fields: [routeId], references: [id], onDelete: SetNull)
  vehicle       Vehicle?       @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  location      DriverLocation?
  payments      Payment[]
  queues        Queue[]
  authCodes     AuthCode[]
  wallet        Wallet?
  cashEntries   CashEntry[]
  ledgerEntries LedgerEntry[]
  queueEvents   QueueEvent[]

  @@index([allianceId, status])
  @@index([routeId, status])
  @@map("drivers")
}

model Route {
  id         BigInt       @id @default(autoincrement())
  allianceId BigInt?      @map("alliance_id")
  name       String
  price      Decimal      @db.Decimal(12, 2)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  alliance   Alliance?    @relation(fields: [allianceId], references: [id], onDelete: SetNull)
  points     RoutePoint[]
  drivers    Driver[]
  vehicles   Vehicle[]

  @@index([allianceId])
  @@map("routes")
}

model RoutePoint {
  id         BigInt    @id @default(autoincrement())
  routeId    BigInt    @map("route_id")
  name       String
  lat        Decimal   @db.Decimal(10, 7)
  lng        Decimal   @db.Decimal(10, 7)
  radius     Int       @default(50)
  createdAt  DateTime  @default(now()) @map("created_at")
  route      Route     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  queues     Queue[]
  counter    QueueCounter?
  events     QueueEvent[]

  @@map("route_points")
}

model Queue {
  id         BigInt      @id @default(autoincrement())
  driverId   BigInt      @map("driver_id")
  pointId    BigInt      @map("point_id")
  position   Int
  status     QueueStatus @default(active)
  createdAt  DateTime    @default(now()) @map("created_at")
  leftAt     DateTime?   @map("left_at")
  driver     Driver      @relation(fields: [driverId], references: [id], onDelete: Cascade)
  point      RoutePoint  @relation(fields: [pointId], references: [id], onDelete: Cascade)
  events     QueueEvent[]

  @@index([pointId, status, position])
  @@map("queues")
}

model QueueCounter {
  pointId       BigInt    @id @map("point_id")
  nextPosition  Int       @default(1) @map("next_position")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  point         RoutePoint @relation(fields: [pointId], references: [id], onDelete: Cascade)

  @@map("queue_counters")
}

model QueueEvent {
  id         BigInt         @id @default(autoincrement())
  queueId     BigInt?        @map("queue_id")
  driverId    BigInt         @map("driver_id")
  pointId     BigInt         @map("point_id")
  eventType   QueueEventType @map("event_type")
  position    Int?
  createdAt   DateTime       @default(now()) @map("created_at")
  queue       Queue?         @relation(fields: [queueId], references: [id], onDelete: SetNull)
  driver      Driver         @relation(fields: [driverId], references: [id], onDelete: Cascade)
  point       RoutePoint     @relation(fields: [pointId], references: [id], onDelete: Cascade)

  @@index([pointId, createdAt])
  @@index([driverId, createdAt])
  @@map("queue_events")
}

model DriverLocation {
  driverId   BigInt    @id @map("driver_id")
  lat        Decimal   @db.Decimal(10, 7)
  lng        Decimal   @db.Decimal(10, 7)
  updatedAt  DateTime  @updatedAt @map("updated_at")
  driver     Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@map("driver_locations")
}

model Payment {
  id                    BigInt         @id @default(autoincrement())
  driverId              BigInt         @map("driver_id")
  vehicleId             BigInt?        @map("vehicle_id")
  amount                Decimal        @db.Decimal(12, 2)
  status                PaymentStatus  @default(pending)
  paymentSystem         PaymentSystem  @map("payment_system")
  externalTransactionId String?        @unique @map("external_transaction_id")
  walletPostedAt        DateTime?      @map("wallet_posted_at")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")
  driver                Driver         @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle               Vehicle?       @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  ledgerEntry           LedgerEntry?

  @@index([vehicleId, createdAt])
  @@index([driverId, createdAt])
  @@map("payments")
}

model AuthCode {
  id         BigInt    @id @default(autoincrement())
  driverId   BigInt?   @map("driver_id")
  phone      String
  code       String
  attempts   Int       @default(0)
  expiresAt  DateTime  @map("expires_at")
  usedAt     DateTime? @map("used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  driver     Driver?   @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@index([phone, createdAt])
  @@map("auth_codes")
}

model PaymentCallbackLog {
  id            BigInt        @id @default(autoincrement())
  provider      PaymentSystem
  transactionId String?       @map("transaction_id")
  driverId      BigInt?       @map("driver_id")
  status        String?
  verified      Boolean       @default(false)
  errorMessage  String?       @map("error_message")
  payload       Json
  createdAt     DateTime      @default(now()) @map("created_at")

  @@index([provider, transactionId])
  @@map("payment_callback_logs")
}

model Wallet {
  id         BigInt        @id @default(autoincrement())
  driverId    BigInt        @unique @map("driver_id")
  balance     Decimal       @db.Decimal(14, 2) @default(0)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  driver      Driver        @relation(fields: [driverId], references: [id], onDelete: Cascade)
  entries     LedgerEntry[]

  @@map("wallets")
}

model CashEntry {
  id             BigInt      @id @default(autoincrement())
  allianceId     BigInt      @map("alliance_id")
  driverId       BigInt      @map("driver_id")
  vehicleId      BigInt?     @map("vehicle_id")
  passengerCount Int         @map("passenger_count")
  fareAmount     Decimal     @db.Decimal(12, 2) @map("fare_amount")
  totalAmount    Decimal     @db.Decimal(12, 2) @map("total_amount")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  alliance       Alliance    @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  driver         Driver      @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle        Vehicle?    @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  ledgerEntry    LedgerEntry?

  @@index([allianceId, createdAt])
  @@index([driverId, createdAt])
  @@map("cash_entries")
}

model LedgerEntry {
  id           BigInt          @id @default(autoincrement())
  walletId      BigInt          @map("wallet_id")
  driverId      BigInt          @map("driver_id")
  paymentId     BigInt?         @unique @map("payment_id")
  cashEntryId   BigInt?         @unique @map("cash_entry_id")
  entryType     LedgerEntryType @map("entry_type")
  amount        Decimal         @db.Decimal(14, 2)
  note          String?
  createdAt     DateTime        @default(now()) @map("created_at")
  wallet        Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  driver        Driver          @relation(fields: [driverId], references: [id], onDelete: Cascade)
  payment       Payment?        @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  cashEntry     CashEntry?      @relation(fields: [cashEntryId], references: [id], onDelete: SetNull)

  @@index([walletId, createdAt])
  @@index([driverId, createdAt])
  @@map("ledger_entries")
}

model Vehicle {
  id          BigInt        @id @default(autoincrement())
  allianceId  BigInt        @map("alliance_id")
  routeId     BigInt?       @map("route_id")
  plateNumber String        @unique @map("plate_number")
  model       String?
  seatCount   Int           @default(11) @map("seat_count")
  qrToken     String        @unique @map("qr_token")
  status      VehicleStatus @default(active)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  alliance    Alliance      @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  route       Route?        @relation(fields: [routeId], references: [id], onDelete: SetNull)
  driver      Driver?
  payments    Payment[]
  cashEntries CashEntry[]

  @@index([allianceId, status])
  @@index([routeId, status])
  @@map("vehicles")
}
