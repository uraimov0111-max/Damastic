{
  "name": "damastic",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run backend:dev",
    "dev:web": "vite --host 0.0.0.0 --port 5173",
    "build": "vite build",
    "build:all": "npm run backend:build && npm run build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "start": "npm --prefix apps/backend run start",
    "mobile:doctor": "powershell -ExecutionPolicy Bypass -File .\\apps\\mobile\\tool\\doctor_mobile.ps1",
    "mobile:bootstrap": "powershell -ExecutionPolicy Bypass -File .\\apps\\mobile\\tool\\bootstrap_mobile.ps1",
    "backend:install": "npm install --prefix apps/backend",
    "backend:build": "npm --prefix apps/backend run build",
    "backend:dev": "npm --prefix apps/backend run start:dev",
    "backend:db:push": "npm --prefix apps/backend run prisma:push",
    "backend:db:seed": "cd apps/backend && npx tsx --env-file=.env prisma/seed.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "leaflet": "^1.9.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "vite": "^7.1.10"
  }
}
